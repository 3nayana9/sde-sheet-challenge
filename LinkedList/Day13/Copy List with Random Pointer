/*
  Problem: Copy List with Random Pointer
  Link: https://leetcode.com/problems/copy-list-with-random-pointer/

  Approach:
  - Brute: Use a HashMap (original node -> clone node) O(n) space
  - Optimal (implemented) — Interleaving, no extra space:
      Pass 1: Insert cloned nodes right after each original node
              1 -> 1' -> 2 -> 2' -> 3 -> 3' -> ...
      Pass 2: Set random pointers for clones:
              temp->next->random = temp->random ? temp->random->next : NULL
      Pass 3: Separate the two lists back

  Time: O(N)  Space: O(1) (excluding output)
*/

class Solution {
public:
    Node* copyRandomList(Node* head) {

        if (head == NULL) return NULL;

        // Pass 1: interleave clones
        Node* temp = head;
        while (temp != NULL) {
            Node* n = new Node(temp->val);
            n->next = temp->next;
            temp->next = n;
            temp = temp->next->next;
        }

        // Pass 2: set random pointers
        temp = head;
        while (temp != NULL) {
            temp->next->random = (temp->random) ? temp->random->next : NULL;
            temp = temp->next->next;
        }

        // Pass 3: separate lists
        Node* dummy = new Node(-1);
        Node* res = dummy;
        temp = head;
        while (temp != NULL) {
            res->next = temp->next;
            temp->next = temp->next->next;
            res = res->next;
            temp = temp->next;
        }

        return dummy->next;
    }
};
