/*
  Problem: Add Two Numbers
  Link: https://leetcode.com/problems/add-two-numbers/

  Approach:
  - Optimal (implemented) — Simulate digit-by-digit addition:
      Use a dummy node for clean head handling.
      At each step: sum = carry + (t1->val if exists) + (t2->val if exists)
      New digit = sum % 10, new carry = sum / 10.
      Loop continues while either list has nodes OR carry is non-zero
      (handles the case where final carry creates an extra node).

  Time: O(max(N, M))  Space: O(max(N, M)) for result list
*/

class Solution {
public:
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        ListNode* t1 = l1;
        ListNode* t2 = l2;

        ListNode* dummy = new ListNode(-1);
        ListNode* curr = dummy;

        int carry = 0;

        while (t1 != NULL || t2 != NULL || carry) {
            int sum = carry;

            if (t1) { sum += t1->val; t1 = t1->next; }
            if (t2) { sum += t2->val; t2 = t2->next; }

            carry = sum / 10;
            curr->next = new ListNode(sum % 10);
            curr = curr->next;
        }

        return dummy->next;
    }
};
