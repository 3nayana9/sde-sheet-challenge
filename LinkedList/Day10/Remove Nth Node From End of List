/*
  Problem: Remove Nth Node From End of List
  Link: https://leetcode.com/problems/remove-nth-node-from-end-of-list/

  Approach:
  - Brute: Find length, traverse to (length - n)th node — two passes O(n)
  - Optimal (implemented) — Two Pointers:
      Move fast pointer n steps ahead.
      If fast == NULL, the head itself is the nth from end — return head->next.
      Then move both slow and fast until fast->next == NULL.
      Now slow is right before the target node.
      slow->next = slow->next->next removes it.

  Time: O(N)  Space: O(1)
*/

class Solution {
public:
    ListNode* removeNthFromEnd(ListNode* head, int n) {
        ListNode* slow = head;
        ListNode* fast = head;

        for (int i = 0; i < n; i++) fast = fast->next;

        if (fast == NULL) return head->next;

        while (fast->next != NULL) {
            slow = slow->next;
            fast = fast->next;
        }

        slow->next = slow->next->next;
        return head;
    }
};
