/*
  Problem: Middle of the Linked List
  Link: https://leetcode.com/problems/middle-of-the-linked-list/

  Approach:
  - Brute: Count length, traverse to length/2 — two passes O(n)
  - Optimal (implemented) — Tortoise and Hare:
      slow moves 1 step, fast moves 2 steps.
      When fast reaches end (NULL or last node), slow is at the middle.
      For even length lists this returns the second middle node.

  Time: O(N)  Space: O(1)
*/

class Solution {
public:
    ListNode* middleNode(ListNode* head) {
        ListNode* slow = head;
        ListNode* fast = head;

        while (fast != NULL && fast->next != NULL) {
            slow = slow->next;
            fast = fast->next->next;
        }
        return slow;
    }
};
