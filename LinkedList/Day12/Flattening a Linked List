/*
  Problem: Flattening a Linked List
  (Each node has next and child pointers; child lists are sorted)

  Approach:
  - Brute: Collect all nodes, sort, rebuild O(n logn)
  - Optimal (implemented) — Recursive merge:
      Recursively flatten from the end (flatten(head->next) first).
      Merge current head's child list with the already-flattened rest
      using merge-two-sorted-lists logic on child pointers.
      Base case: if head is NULL or head->next is NULL, return head.

  Time: O(N*M) where N = nodes in main list, M = avg child list length
  Space: O(N) recursion stack
*/

Node* merge2Lists(Node* l1, Node* l2) {

    Node* dummy = new Node(-1);
    Node* res = dummy;

    while (l1 != NULL && l2 != NULL) {
        if (l1->data < l2->data) {
            res->child = l1;
            res = l1;
            l1 = l1->child;
        } else {
            res->child = l2;
            res = l2;
            l2 = l2->child;
        }
        res->next = NULL;
    }

    if (l1) res->child = l1;
    else res->child = l2;

    return dummy->child;
}

Node* flatten(Node* head) {
    if (head == NULL || head->next == NULL) return head;
    Node* mergehead = flatten(head->next);
    return merge2Lists(head, mergehead);
}
