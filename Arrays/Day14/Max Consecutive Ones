/*
  Problem: Max Consecutive Ones
  Link: https://leetcode.com/problems/max-consecutive-ones/

  Approach:
  - Optimal (implemented):
      Keep a running count, reset to 0 on seeing a 0.
      Track max count throughout.

  Time: O(N)  Space: O(1)
*/

class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int maxi = 0, cnt = 0;
        for (int i = 0; i < nums.size(); i++) {
            if (nums[i] == 0) cnt = 0;
            else cnt++;
            maxi = max(cnt, maxi);
        }
        return maxi;
    }
};
