class Solution {
public:
    int maxProfit(vector<int>& prices) {
        
        int maxPro = 0 , mini = prices[0];

        for(int i=0;i<prices.size();i++){

            if(prices[i] < mini) mini = prices[i];

            maxPro = max(maxPro , (prices[i] - mini));
        }

        return maxPro;
    }
};
