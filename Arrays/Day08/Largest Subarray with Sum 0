/*
  Problem: Largest Subarray with Sum 0

  Approach:
  - Brute: Generate all subarrays and check sum O(n^2)
  - Optimal (implemented) — Prefix Sum + HashMap:
      Maintain a running sum. Store (sum -> index) in a hashmap.
      If sum == 0 at index i, the subarray from 0 to i has sum 0, length = i+1.
      If sum was seen before at index j, subarray from j+1 to i has sum 0.
      Only store the first occurrence of each sum to maximize length.

  Time: O(N)  Space: O(N)
*/

int largestSubarrayWithSum0(vector<int> arr, int N) {

    unordered_map<int, int> mp;
    int sum = 0;
    int maxi = INT_MIN;

    for (int i = 0; i < N; i++) {
        sum += arr[i];

        if (sum == 0) {
            maxi = i + 1;
        } else {
            if (mp.find(sum) == mp.end()) {
                mp[sum] = i;
            } else {
                maxi = max(i - mp[sum], maxi);
            }
        }
    }
    return maxi;
}
